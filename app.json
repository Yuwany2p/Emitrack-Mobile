{
  "expo": {
    "name": "emitrack-mobile",
    "slug": "emitrack-mobile",
    "scheme": "emitrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.emitrackmobile",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDFtIzi9G1HgD1XR8AJNDCgkWJX09qib70"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ]
  }
}
